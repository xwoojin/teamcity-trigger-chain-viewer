<?xml version="1.0" encoding="UTF-8"?>
<teamcity-plugin xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:noNamespaceSchemaLocation="urn:shemas-jetbrains-com:teamcity-plugin-v2-xml">
  <info>
    <name>trigger-chain-view</name>
    <display-name>Trigger Chain View</display-name>
    <version>260407.1</version>
    <description>Visualizes finish build trigger chains for each build configuration. Shows downstream triggered builds as a recursive tree, making it easy to understand the full trigger chain flow.</description>
    <vendor>
      <name>WooJin Kim</name>
      <url>https://github.com/xwoojin/teamcity-trigger-chain-viewer</url>
    </vendor>
  </info>
  <requirements min-build="208117" />
  <deployment use-separate-classloader="true" />
</teamcity-plugin>
